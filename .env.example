# ProspectionCockpit - Variables d'environnement
# Copier en .env et remplir

# Database
DATABASE_URL=postgresql+psycopg://prospection:prospection_dev@localhost:5432/prospection_cockpit

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (DeepSeek prioritaire via LiteLLM)
DEEPSEEK_API_KEY=sk-...
LITELLM_API_KEY=   # optionnel si clés directes

# Autres providers (futur)
# BREVO_API_KEY=...
# TWILIO_ACCOUNT_SID=...
